<div id="<%= dom_id user %>">
  <p>
    <strong>User login:</strong>
    <%= user.user_login %>
  </p>

  <p>
    <strong>User password:</strong>
    <%= user.user_password %>
  </p>

  <p>
    <strong>Email:</strong>
    <%= user.email %>
  </p>

  <p>
    <strong>Is real admin:</strong>
    <%= user.is_real_admin %>
  </p>

  <p>
    <strong>Hobbies:</strong>
    <%= user.hobbies %>
  </p>

</div>
