<%= form_with(model: user_desc) do |form| %>
  <% if user_desc.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(user_desc.errors.count, "error") %> prohibited this user_desc from being saved:</h2>

      <ul>
        <% user_desc.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
